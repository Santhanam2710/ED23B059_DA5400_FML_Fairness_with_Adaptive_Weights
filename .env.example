# ── Experiment selector ──────────────────────────────────────────
# Which experiment(s) to run. Comma-separated, any subset of:
#   main, alpha_sweep, noise_robustness, all
EXPERIMENTS=all

# ── Dataset / model knobs ────────────────────────────────────────
SEEDS=0,1,2,3,4
TEST_SIZE=0.2

# Alpha values: used by the main experiment (one per dataset)
ALPHA_ADULT=10.0
ALPHA_GERMAN=2.0

# Alpha sweep grid (log-spaced)
ALPHA_GRID=0.1,0.5,1.0,2.0,5.0,10.0,20.0,50.0

# Noise robustness grid
NOISE_RATIOS=0.0,0.05,0.10,0.15,0.20,0.25,0.30

# ── Output ───────────────────────────────────────────────────────
RESULTS_DIR=results
